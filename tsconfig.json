{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Node",
        "target": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "skipLibCheck": true,
        "outDir": "dist",
        "allowJs": true,
        "esModuleInterop": true
    },
    "include": [
        "src/**/*.ts"
    ]
}
