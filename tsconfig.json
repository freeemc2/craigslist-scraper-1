{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "outDir": "dist",
        "rootDir": "src",
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": false,
        "esModuleInterop": true,
        "allowImportingTsExtensions": false,
        "noEmit": false
    },
    "include": ["src/**/*.ts"]
}
